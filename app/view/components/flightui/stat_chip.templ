package flightui

templ StatChip(label, value string) {
	if value != "" {
		<div class="rounded-lg border border-border/80 bg-background/80 px-3 py-2 backdrop-blur-sm">
			<div class="text-[10px] font-medium uppercase tracking-wider text-muted-foreground">{ label }</div>
			<div class="mt-0.5 font-mono text-sm font-semibold text-foreground">{ value }</div>
		</div>
	}
}
