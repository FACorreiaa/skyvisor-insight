# Server
ADDR=127.0.0.1:6969
WRITE_TIMEOUT=15s
READ_TIMEOUT=15s
IDLE_TIMEOUT=60s
GRACEFUL_TIMEOUT=5s
SESSION_KEY=
COOKIE_SECURE=false

# Postgres
DB_PASS=
DB_PORT=
DB_USER=
DB_NAME=
DB_HOST=

# pprof
PPROF_ADDR=
PPROF_PORT=

DB_PG_PROD=

# Redis
REDIS_HOST=
REDIS_PASS=
REDIS_DB=

UPSTASH_URL=

MODE=
SCHEMA=
AVIATION_STACK_API_KEY=

# OIDC login (Auth0 or any OIDC provider). Leave empty to disable sign-in.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://localhost:6969/auth/callback
# API identifier for skyvisor-api access tokens (Auth0 audience).
OIDC_AUDIENCE=

# skyvisor-api base URL for trips/assistant/billing calls.
SKYVISOR_API_URL=http://127.0.0.1:8080

# Observability (optional; empty disables)
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
SENTRY_ENVIRONMENT=
POSTHOG_KEY=
POSTHOG_HOST=
