# Application
MODE=development
LOG_LEVEL=info
LOG_FORMAT=text
ADDR=127.0.0.1:6969
WRITE_TIMEOUT=15s
READ_TIMEOUT=15s
IDLE_TIMEOUT=60s
GRACEFUL_TIMEOUT=5s
SESSION_KEY=replace-with-at-least-32-random-characters
COOKIE_SECURE=false

# PostgreSQL. DATABASE_URL takes precedence when set.
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5435
DB_USER=postgres
DB_PASS=replace-me
DB_NAME=aviation-tracker-dev
DB_SCHEMA=

# Apply embedded SQL migrations on web process start (default true).
# Set false to rely only on go run ./cmd/migrate or the Helm migrate Job.
AUTO_MIGRATE=true

# Redis
REDIS_HOST=127.0.0.1:6381
REDIS_PASS=

# Companion API and live aviation data
SKYVISOR_API_URL=http://127.0.0.1:8080
AVIATION_STACK_API_KEY=

# Optional OIDC login. Set issuer, client ID, and redirect URL together.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=
OIDC_AUDIENCE=
